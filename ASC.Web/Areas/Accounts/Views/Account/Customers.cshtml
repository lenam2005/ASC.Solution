@using Microsoft.AspNetCore.Identity
@model ASC.Web.Areas.Accounts.Models.CustomerViewModel
@inject UserManager<IdentityUser> userManager

@{
    Layout = "_SecureLayout";
}

<div>
    <div class="row"></div>

    <div class="row padding-left-20px padding-right-20px">

        <div class="row z-depth-3">
            <div class="col s12 padding-0px">
                <div class="section white-text padding-left-10px blue-grey lighten-1">
                    <h5>Users</h5>
                </div>
            </div>

            <div class="divider"></div>

            <div class="col s12 padding-bottom-15px">
                @if (Model.Customers != null)
                {
                    <table class="highlight centered" id="tblCustomers">
                        <thead>
                            <tr>
                                <th>Email</th>
                                <th>Is Active</th>
                                <th>Status</th>
                                <th>Edit User</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var user in Model.Customers)
                            {
                                var identity = await userManager.GetClaimsAsync(user);
                                var isActive = identity.FirstOrDefault(p => p.Type == "IsActive")?.Value == "True";

                                <tr>
                                    <td>@user.Email</td>
                                    <td>@isActive</td>
                                    <td>@(isActive ? "Active" : "Not Active")</td>
                                    <td>
                                        <i class="small material-icons edit cursor-hand">mode_edit</i>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
            </div>
        </div>

        <div class="row z-depth-3">
            <div class="col s12 padding-0px">
                <div class="section white-text padding-left-10px blue-grey lighten-1">
                    <h5>Customer Details</h5>
                </div>
            </div>

            <div class="divider"></div>

            <form asp-controller="Account" asp-action="Customers" method="post" class="col s12" id="fromUser">
                <input type="hidden" asp-for="Registration.IsEdit" id="Registration_IsEdit" />

                <div class="input-field col s4">
                    <input asp-for="Registration.Email" id="Registration_Email" />
                    <label asp-for="Registration.Email"></label>
                </div>

                <div class="input-field col s4">
                    <div class="switch">
                        <label>
                            Is Active
                            <input asp-for="Registration.IsActive" id="Registration_IsActive" />
                            <span class="lever"></span>
                        </label>
                    </div>
                </div>

                <div class="input-field col s4 right-align">
                    <button class="btn waves-effect waves-light btnSubmit" type="submit">
                        Save
                        <i class="material-icons right">send</i>
                    </button>

                    <button class="btn waves-effect waves-light reset red lighten-1" type="button">
                        Reset
                    </button>
                </div>

                <div class="row col s12 right-align" asp-validation-summary="All"></div>
            </form>
        </div>

    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            $('#tblCustomers').DataTable({
                "pageLength": 3,
                "lengthMenu": [[3, 5, 10, -1], [3, 5, 10, "All"]]
            });

            $('.btnSubmit').attr('disabled', 'disabled');

            $(document).on('click', '.reset', function () {
                $('#fromUser')[0].reset();
                $('#Registration_Email').val('').removeAttr('readonly');
                $('#Registration_IsEdit').val('False');
                $('#Registration_IsActive').prop('checked', false);
                $('.btnSubmit').attr('disabled', 'disabled');
                M.updateTextFields();
            });

            $(document).on('click', '.edit', function () {
                var row = $(this).closest('tr');
                var email = row.find('td:eq(0)').text().trim();
                var isActiveText = row.find('td:eq(1)').text().trim();

                $('#Registration_IsEdit').val('True');
                $('#Registration_Email').val(email).attr('readonly', true);
                $('#Registration_IsActive').prop('checked', isActiveText === 'True');

                $('.btnSubmit').removeAttr('disabled');
                M.updateTextFields();
            });
        });
    </script>
}