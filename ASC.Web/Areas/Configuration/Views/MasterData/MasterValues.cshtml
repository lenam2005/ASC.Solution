@model ASC.Web.Areas.Configuration.Models.MasterValuesViewModel
@{
    Layout = "_SecureLayout";
}

<div class="row"></div>

<div class="row padding-top-20px padding-left-20px padding-right-20px">
    <div class="row z-depth-3">
        <div class="section white-text padding-left-10px blue-grey lighten-1">
            <h5>Master Values</h5>
        </div>

        <div class="divider"></div>

        <div class="row padding-top-20px">
            <div class="input-field col s4">
                <select id="ddlMasterKeys">
                    <option value="">--Select--</option>

                    @if (ViewBag.MasterKeys != null)
                    {
                        foreach (var item in ViewBag.MasterKeys)
                        {
                            <option value="@item.PartitionKey">@item.PartitionKey</option>
                        }
                    }
                </select>
                <label>Partition Key</label>
            </div>

            <div class="col s4 offset-s4 padding-bottom-15px right-align">
                <a class="modal-trigger waves-effect waves-light" href="#modal1">
                    <i class="material-icons small green-text">description</i>
                </a>
            </div>
        </div>

        <div class="col s12 padding-bottom-15px">
            <table class="highlight centered" id="tblMasterValues">
                <thead>
                    <tr>
                        <th>Row Key</th>
                        <th>Partition Key</th>
                        <th>Name</th>
                        <th>Is Active</th>
                        <th>Edit</th>
                    </tr>
                </thead>
            </table>
        </div>
    </div>
</div>

<div class="row padding-left-20px padding-right-20px">
    <div class="row z-depth-3">
        <div class="col s12 padding-0px">
            <div class="section white-text padding-left-10px blue-grey lighten-1">
                <h5>Master Value Details</h5>
            </div>

            <div class="divider"></div>

            <form asp-area="Configuration"
                  asp-controller="MasterData"
                  asp-action="MasterValues"
                  method="post"
                  class="col s12"
                  id="formMasterValue">

                @Html.AntiForgeryToken()

                <input type="hidden"
                       id="IsEdit"
                       name="IsEdit"
                       value="False" />

                <input type="hidden"
                       id="MasterValueInContext_RowKey"
                       name="MasterValueInContext.RowKey" />

                <input type="hidden"
                       id="MasterValueInContext_PartitionKey"
                       name="MasterValueInContext.PartitionKey" />

                <div class="row padding-top-20px">
                    <div class="input-field col s4">
                        <input id="Input_MasterValue_RowKey"
                               name="Input_MasterValue_RowKey"
                               type="text"
                               class="validate"
                               readonly />
                        <label for="Input_MasterValue_RowKey">RowKey</label>
                    </div>

                    <div class="input-field col s4">
                        <select id="Select_MasterValueInContext_PartitionKey"
                                required="required">
                            <option value="">--Select--</option>

                            @if (ViewBag.MasterKeys != null)
                            {
                                foreach (var item in ViewBag.MasterKeys)
                                {
                                    <option value="@item.PartitionKey">@item.PartitionKey</option>
                                }
                            }
                        </select>
                        <label>Partition Key</label>
                    </div>

                    <div class="input-field col s4">
                        <input id="MasterValueInContext_Name"
                               name="MasterValueInContext.Name"
                               type="text"
                               class="validate"
                               required="required" />
                        <label for="MasterValueInContext_Name">Name</label>
                    </div>
                </div>

                <div class="row">
                    <div class="input-field col s4">
                        <p style="margin-top:0; color:#9e9e9e;">Is Active</p>

                        <div class="switch">
                            <label>
                                Off
                                <input id="MasterValueInContext_IsActive"
                                       name="MasterValueInContext.IsActive"
                                       type="checkbox"
                                       value="true" />
                                <span class="lever"></span>
                                On
                            </label>
                        </div>

                        <input type="hidden"
                               name="MasterValueInContext.IsActive"
                               value="false" />
                    </div>

                    <div class="input-field col s8 right-align">
                        <button class="btn waves-effect waves-light btnSubmit teal"
                                type="button"
                                id="btnCreate">
                            CREATE
                            <i class="material-icons right">send</i>
                        </button>

                        <button class="btn waves-effect waves-light reset red lighten-1"
                                type="button"
                                id="btnReset">
                            RESET
                        </button>
                    </div>
                </div>

                <div class="row">
                    <div class="col s12 red-text" asp-validation-summary="All"></div>
                </div>
            </form>
        </div>
    </div>
</div>

<div class="row"></div>

<div id="modal1" class="modal modal-fixed-footer">
    <div class="modal-content">
        <h4>Upload Excel</h4>
        <p>Upload the Excel file that contains all the master values.</p>

        <div class="row hide divErrors">
            <div class="col s12">
                <div class="card-panel red lighten-1">
                    <span class="white-text errors"></span>
                </div>
            </div>
        </div>

        <div class="progress hide">
            <div class="indeterminate"></div>
        </div>

        <form id="formUploadExcel" method="post" enctype="multipart/form-data">
            @Html.AntiForgeryToken()

            <div class="file-field input-field">
                <div class="btn">
                    <span>File</span>
                    <input type="file" id="files" />
                </div>

                <div class="file-path-wrapper">
                    <input class="file-path validate" type="text" />
                </div>

                <div class="input-field row right">
                    <button class="btn waves-effect waves-light btnUpload"
                            type="button"
                            name="action">
                        Upload
                        <i class="material-icons right">send</i>
                    </button>
                </div>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {

            console.log("MasterValues script loaded");

            var token = $('input[name="__RequestVerificationToken"]').first().val();

            $.ajaxSetup({
                cache: false,
                headers: {
                    'RequestVerificationToken': token,
                    'X-CSRF-TOKEN': token
                }
            });

            $('select').formSelect();
            $('.modal').modal();

            var table = $('#tblMasterValues').DataTable({
                ajax: {
                    url: '@Url.Action("MasterValuesByKey", "MasterData")',
                    type: 'GET',
                    data: function (d) {
                        d.key = $('#ddlMasterKeys').val();
                    }
                },
                pageLength: 3,
                lengthMenu: [[3, 5, 10, -1], [3, 5, 10, 'All']],
                autoWidth: false,
                columns: [
                    { data: 'RowKey' },
                    { data: 'PartitionKey' },
                    { data: 'Name' },
                    { data: 'IsActive' },
                    { data: null }
                ],
                columnDefs: [
                    {
                        targets: 3,
                        render: function (data, type, row) {
                            if (data === true || data === 'True' || data === 'true') {
                                return '<i class="material-icons green-text">check</i>';
                            }

                            return '<i class="material-icons red-text">close</i>';
                        }
                    },
                    {
                        targets: 4,
                        render: function (data, type, row) {
                            return '<i class="small material-icons edit cursor-hand">mode_edit</i>';
                        }
                    }
                ]
            });

            $('#tblMasterValues').css("width", "100%");
            $('#tblMasterValues_length select').formSelect();

            $(document).on('change', '#ddlMasterKeys', function () {
                var selectedKey = $('#ddlMasterKeys').val();

                $('#Select_MasterValueInContext_PartitionKey').formSelect('destroy');
                $('#Select_MasterValueInContext_PartitionKey').val(selectedKey);
                $('#Select_MasterValueInContext_PartitionKey').formSelect();

                $('#MasterValueInContext_PartitionKey').val(selectedKey);

                table.ajax.reload();
            });

            $(document).on("click", ".reset", function () {
                var selectedKey = $('#ddlMasterKeys').val();

                $('#formMasterValue')[0].reset();

                $('#IsEdit').val('False');
                $('#MasterValueInContext_RowKey').val('');
                $('#Input_MasterValue_RowKey').val('');
                $('#MasterValueInContext_PartitionKey').val(selectedKey);
                $('#MasterValueInContext_Name').val('');
                $('#MasterValueInContext_IsActive').prop('checked', false);

                $('#Select_MasterValueInContext_PartitionKey').formSelect('destroy');
                $('#Select_MasterValueInContext_PartitionKey').removeAttr('disabled');
                $('#Select_MasterValueInContext_PartitionKey').val(selectedKey);
                $('#Select_MasterValueInContext_PartitionKey').formSelect();

                $('.btnSubmit').html('CREATE <i class="material-icons right">send</i>');
                $('.select-wrapper').removeClass('valid');

                M.updateTextFields();

                console.log("Form reset");
            });

            $(document).on('click', '.edit', function () {
                var rowData = $('#tblMasterValues')
                    .DataTable()
                    .row($(this).closest('tr'))
                    .data();

                console.log("Edit row data:", rowData);

                if (!rowData) {
                    alert("Không lấy được dữ liệu dòng này.");
                    return;
                }

                $('#IsEdit').val('True');

                $('#MasterValueInContext_RowKey').val(rowData.RowKey);
                $('#Input_MasterValue_RowKey').val(rowData.RowKey);

                $('#MasterValueInContext_PartitionKey').val(rowData.PartitionKey);

                $('#Select_MasterValueInContext_PartitionKey').formSelect('destroy');
                $('#Select_MasterValueInContext_PartitionKey').val(rowData.PartitionKey);
                $('#Select_MasterValueInContext_PartitionKey').attr('disabled', 'disabled');
                $('#Select_MasterValueInContext_PartitionKey').formSelect();

                $('#MasterValueInContext_Name').val(rowData.Name);

                $('#MasterValueInContext_IsActive').prop(
                    'checked',
                    rowData.IsActive === true ||
                    rowData.IsActive === 'True' ||
                    rowData.IsActive === 'true'
                );

                $('.btnSubmit').html('SAVE');

                $('.select-wrapper').removeClass('valid');

                M.updateTextFields();
            });

            $(document).on('click', '.btnSubmit', function () {
                var selectedPartitionKey = $('#Select_MasterValueInContext_PartitionKey').val();
                var name = $('#MasterValueInContext_Name').val();

                if (!selectedPartitionKey || selectedPartitionKey.trim() === '') {
                    alert("Bạn phải chọn Partition Key.");
                    return;
                }

                if (!name || name.trim() === '') {
                    alert("Bạn phải nhập Name.");
                    return;
                }

                var masterData = {
                    RowKey: $('#MasterValueInContext_RowKey').val(),
                    PartitionKey: selectedPartitionKey,
                    Name: name.trim(),
                    IsActive: $('#MasterValueInContext_IsActive').is(':checked')
                };

                console.log("POST MasterValue:", masterData);
                console.log("IsEdit:", $('#IsEdit').val());

                $.post('@Url.Action("MasterValues", "MasterData")',
                    {
                        masterValue: masterData,
                        isEdit: $('#IsEdit').val()
                    },
                    function (data, status, xhr) {
                        console.log("Save result:", data);

                        if (data === true || data === "true") {
                            table.ajax.reload();

                            var selectedKey = $('#ddlMasterKeys').val();

                            $('.reset').click();

                            $('#Select_MasterValueInContext_PartitionKey').formSelect('destroy');
                            $('#Select_MasterValueInContext_PartitionKey').val(selectedKey);
                            $('#Select_MasterValueInContext_PartitionKey').formSelect();

                            $('#MasterValueInContext_PartitionKey').val(selectedKey);
                        } else {
                            alert("Lưu không thành công: " + data);
                        }
                    }
                ).fail(function (xhr) {
                    console.log(xhr.responseText);
                    alert("Lưu Master Value bị lỗi. Xem Console/Network để biết chi tiết.");
                });
            });

            $(document).on('click', '.btnUpload', function () {
                var fileUpload = $("#files").get(0);
                var files = fileUpload.files;

                if (!files || files.length === 0) {
                    alert("Bạn chưa chọn file Excel.");
                    return;
                }

                var data = new FormData();

                $.each(files, function (i) {
                    data.append(files[i].name, files[i]);
                });

                $(".progress").removeClass("hide");

                $.ajax({
                    type: "POST",
                    url: "/Configuration/MasterData/UploadExcel",
                    contentType: false,
                    processData: false,
                    data: data,
                    success: function (message) {
                        $(".progress").addClass("hide");

                        if (message.success || message.Success) {
                            window.location.reload();
                        }

                        if (message.error || message.Error) {
                            $(".divErrors").removeClass("hide");
                            $(".errors").html(message.text || message.Text);
                        }
                    },
                    error: function (xhr) {
                        $(".progress").addClass("hide");
                        console.log(xhr.responseText);
                        alert("Upload Excel bị lỗi.");
                    }
                });
            });

        });
    </script>
}