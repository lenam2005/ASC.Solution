@using ASC.Model.BaseTypes
@{
    Layout = "_SecureLayout";
}

<div class="section">
    <div class="row">
        <div class="col s12">

            @await Html.PartialAsync("_ServiceRequestGrid", Model.ServiceRequests,
                     new ViewDataDictionary(ViewData)
            {
            { "SectionName", "Service Requests" },
            { "Id", "tblServiceRequests" },
            { "IsAudit", false }
            })

        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {

            var table = $('#tblServiceRequests').DataTable({
                'pageLength': 3,
                'lengthMenu': [[3, 5, 10, -1], [3, 5, 10, "All"]],
                'sorting': [],
                'columns': [
                    { "visible": false },
                    { "visible": false },
                    null,   
                    { "width": "20%" },
                    null,
                    null,
                    null
                ]
            });

            $('#tblServiceRequests').css("width", "100%");
            $('select[name="tblServiceRequests_length"]').formSelect();
        });
    </script>
}